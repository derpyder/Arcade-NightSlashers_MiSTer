<!--  Night Slashers (Data East, 1994) — deco32 / encrypted ARM6 core for MiSTer.
      Port by rejectedcoins, built on JTFRAME by Jose Tejada (jotego). License: GPLv3.

      v1.1 (2026-07-04): SOUND UPDATE - rebalanced audio mix (music down, voice up, SFX),
      diffed per-channel vs MAME. EEPROM now ships BLANK so each set self-configures its
      region on first boot (restores per-region gore, incl. Japan/Korea). Over Sea CRCs fixed.

      v1.0 (2026-07-02): full video pipeline HW-verified — dual DECO 52/153 sprite
      chips, 4 playfields (per-tile flip + rowscroll-ready), Ace (chip 99) palette
      fade + variable alpha (stage-2 mist, carriage transparency, shadows), joint-8bpp
      portrait mode (bios/story art), 93C46 EEPROM, service menu, YM2151 + 2x OKI.

      NOTE: this MRA encodes a CUSTOM SDRAM layout (obj0 8-byte-slot single-burst in
      BA3, obj4/obj1 in the BA2 tail, doubled plane4 streams) — do not replace it with
      a stock jtframe-generated MRA.
-->
<misterromdescription>
    <about author="rejectedcoins" webpage="https://patreon.com/jotego" twitter="@topapate" source="https://jotego/jtcores"/>
    <rotation>horizontal</rotation>
    <name>Night Slashers (Over Sea Rev 1.2)</name>
    <setname>nslashers</setname>
    <mameversion>0284</mameversion>
    <year>1994</year>
    <manufacturer>Data East Corporation</manufacturer>
    <players>3</players>
    <rbf>jtnslasher</rbf>
    <joystick>8</joystick>
    <region>World</region>
    <rom index="0" zip="nslashers.zip|nslasher.zip" md5="None">
        <!-- maincpu - starts at 0x0 - length 0x100000 (20 bits) -->
        <interleave output="32">
            <part name="ly-01.2f" crc="ae508149" map="0012"/>
            <part name="ly-00.1f" crc="fa0646f9" map="1200"/>
        </interleave>
        <!-- SND_START -->
        <!-- audiocpu - starts at 0x100000 - length 0x10000 (16 bits) -->
        <part name="sndprg.17l" crc="18939e92"/>
        <!-- PCM1_START -->
        <!-- oki1 - starts at 0x110000 - length 0x80000 (19 bits) -->
        <part name="mbh-10.14l" crc="c4d6b116"/>
        <!-- PCM2_START -->
        <!-- oki2 - starts at 0x190000 - length 0x80000 (19 bits) -->
        <part name="mbh-11.16l" crc="0ec40b6b"/>
        <!-- JTFRAME_BA2_START -->
        <!-- tiles1 - starts at 0x210000 - length 0x200000 (21 bits) -->
        <part name="mbh-00.8c" crc="a877f8a3"/>
        <!-- GFX2_START -->
        <!-- tiles2 - starts at 0x410000 - length 0x200000 (21 bits) -->
        <part name="mbh-01.9c" crc="1853dafc"/>
        <!-- GFX4_START (gfx4/obj1 RELOCATED BA3->BA2 tail, BA2-rel 0x400000) -->
        <!-- sprites2 - starts at 0x610000 - length 0x100000 (20 bits) -->
        <interleave output="16">
            <part name="mbh-08.16e" crc="cdd7f8cb" map="01"/>
            <part name="mbh-09.18e" crc="33fa2121" map="10"/>
        </interleave>
        <!-- JTFRAME_BA3_START (moved 0x610000 -> 0x710000) -->
        <!-- sprites1a - starts at 0x710000 - length 0x400000 (22 bits) -->
        <interleave output="16">
            <part name="mbh-02.14c" crc="b2f158a1" map="01"/>
            <part name="mbh-04.16c" crc="eecfe06d" map="10"/>
        </interleave>
        <!-- SPR1B_START -->
        <!-- sprites1b - starts at 0xB10000 - length 0x100000 (20 bits) -->
        <interleave output="16">
            <part name="mbh-03.15c" crc="787787e3" map="01"/>
            <part name="mbh-05.17c" crc="1d2b7c17" map="10"/>
        </interleave>
        <!-- SPR1C_START -->
        <!-- obj0hi6 DOUBLED (1 plane4 byte / 16-bit word, EVEN lane) - starts at 0xC10000 - length 0x200000 -->
        <interleave output="16">
            <part name="mbh-06.18c" crc="" map="01" length="0x100000"/>
        </interleave>
        <!-- SPR1D_START -->
        <!-- obj0hi7 DOUBLED - starts at 0xE10000 - length 0x80000 -->
        <interleave output="16">
            <part name="mbh-07.19c" crc="" map="01" length="0x40000"/>
        </interleave>
        <!-- Total 0xE90000 bytes - 14912 kBytes -->
    </rom>
    <rom index="1">
        <part>00 80</part>
    </rom>
    <buttons names="Attack,Jump,Special,Start,Coin,Core credits" default="A,B,X,Start,Select,-" count="3"/>
</misterromdescription>
